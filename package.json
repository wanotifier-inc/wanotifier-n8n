{
	"name": "n8n-nodes-wanotifier",
	"version": "1.0.3",
	"description": "n8n community node for WANotifier — WhatsApp marketing automation built on the official WhatsApp API. Create or update contacts, send free-form messages during an active conversation window, and fire transactional notifications using pre-configured message templates.",
	"license": "MIT",
	"homepage": "https://github.com/wanotifier-inc/wanotifier-n8n",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"wanotifier",
		"whatsapp",
		"whatsapp business",
		"whatsapp business api",
		"whatsapp api",
		"whatsapp messaging",
		"whatsapp automation",
		"whatsapp marketing",
		"messaging",
		"chat",
		"chatbot",
		"customer engagement",
		"transactional",
		"marketing automation"
	],
	"author": {
		"name": "WANotifier",
		"email": "hello@wanotifier.com",
		"url": "https://wanotifier.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/wanotifier-inc/wanotifier-n8n.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/WANotifierApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/WANotifier/WANotifier.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "10.3.0",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
